gestures {
    hot-corners {
        off
    }
}

input {
    warp-mouse-to-focus
    focus-follows-mouse max-scroll-amount="0%"
    keyboard {
        xkb {
        }
        numlock
    }
    touchpad {
        natural-scroll
        scroll-factor 0.5
    }
    mouse {
    }
    trackpoint {
    }
}
